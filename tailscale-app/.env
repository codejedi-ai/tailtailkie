# Tailscale Auth Key (get from https://login.tailscale.com/admin/settings/keys)
# IMPORTANT: Replace with your actual auth key
TS_AUTHKEY=tskey-auth-ku9o3kusH211CNTRL-icCwViijUiNjpTsLGiFjiNs7K75ZhBGWa

# Bridge Identity (must be unique per agent/bridge)
BRIDGE_NAME=nanobot-bridge

# State Directory (persistent storage for Tailscale identity)
TSNET_STATE_DIR=./state/nanobot-bridge

# Bridge Ports
BRIDGE_INBOUND_PORT=8001
PEER_BRIDGE_INBOUND_PORT=8001
BRIDGE_LOCAL_LISTEN=127.0.0.1:8080

# Local Agent API Endpoint
LOCAL_AGENT_URL=http://127.0.0.1:9090/api

# Optional: HMAC Secret (set same value on all trusted bridges)
BRIDGE_HMAC_SECRET=replace-with-shared-secret
