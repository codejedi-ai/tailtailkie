# MongoDB Configuration
# For local MongoDB (Docker Compose)
MONGODB_ROOT_USERNAME=admin
MONGODB_ROOT_PASSWORD=changeme

# For cloud MongoDB (MongoDB Atlas) - use DATABASE_URL instead
# DATABASE_URL=mongodb+srv://user:password@cluster.mongodb.net/tensorstore?retryWrites=true&w=majority

# Milvus Configuration
# For local Milvus (Docker Compose)
# MILVUS_URI=http://milvus:19530
# MILVUS_TOKEN=
# MILVUS_USER=

# For cloud Milvus (Zilliz Cloud)
# MILVUS_URI=https://your-instance.serverless.gcp-us-west1.cloud.zilliz.com
# MILVUS_TOKEN=your_token_here
# MILVUS_USER=your_user_here

# Clerk Authentication
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_FRONTEND_API=https://api.clerk.com
CLERK_WEBHOOK_SECRET=

# Clerk URLs (for Next.js frontend)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# Application Configuration
ENVIRONMENT=development
BUILD_VERSION=1.0.0

# MinIO (for Milvus - only if using local Milvus)
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

