{
  "name": "tensorstore-backend",
  "version": "2.0.0",
  "description": "TensorStore Backend API - Flask-based REST API for managing tensor datasets.",
  "main": "index.js",
  "author": "TensorStore Team",
  "license": "MIT",
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.{js,ts,tsx}": [
      "eslint --fix"
    ]
  },
  "scripts": {
    "start": "webpack-dev-server --mode development --config webpack.dev.config.js",
    "build": "webpack --mode production --config webpack.prod.config.js",
    "lint": "eslint ./app/src",
    "test": "jest --collect-coverage"
  },
  "dependencies": {
    "axios": "0.24.0",
    "react": "17.0.2",
    "react-dom": "17.0.2",
    "react-google-login": "5.2.2",
    "react-router-dom": "5.3.0",
    "styled-components": "5.3.3",
    "typescript": "4.4.4"
  },
  "devDependencies": {
    "@babel/cli": "^7.16.0",
    "@babel/core": "^7.16.0",
    "@babel/preset-env": "^7.16.0",
    "@babel/preset-react": "^7.16.0",
    "@types/node": "^16.11.6",
    "@types/react": "^17.0.33",
    "@types/react-dom": "^17.0.10",
    "@types/react-router-dom": "^5.3.2",
    "@types/styled-components": "^5.1.15",
    "@typescript-eslint/eslint-plugin": "^5.2.0",
    "@typescript-eslint/parser": "^5.3.1",
    "babel-loader": "^8.2.3",
    "create-file-webpack-plugin": "^1.0.1",
    "css-loader": "^6.5.0",
    "eslint": "^8.1.0",
    "eslint-config-prettier": "^8.3.0",
    "eslint-import-resolver-typescript": "^2.5.0",
    "eslint-loader": "^4.0.2",
    "eslint-plugin-import": "^2.25.2",
    "eslint-plugin-prettier": "^4.0.0",
    "eslint-plugin-react": "^7.26.1",
    "file-loader": "^6.2.0",
    "html-webpack-plugin": "^5.5.0",
    "prettier": "^2.4.1",
    "react-hot-loader": "^4.13.0",
    "source-map-loader": "^3.0.0",
    "static-site-generator-webpack-plugin": "^3.4.2",
    "style-loader": "^3.3.1",
    "ts-loader": "^9.2.6",
    "webpack": "^5.61.0",
    "webpack-cli": "^4.9.1",
    "webpack-dev-server": "^4.4.0",
    "write": "^2.0.0"
  }
}
