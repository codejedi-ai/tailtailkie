#!/bin/bash

set -e

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

echo -e "${GREEN}=== Building and Starting TensorStore ===${NC}\n"

# Check/create .env
if [ ! -f .env ]; then
    echo -e "${YELLOW}Creating .env from env.example...${NC}"
    cp env.example .env
    echo -e "${RED}IMPORTANT: Edit .env with your actual secrets!${NC}\n"
    exit 1
fi

# Load .env and generate docker-secrets.env
echo -e "${GREEN}Loading secrets...${NC}"
export $(grep -v '^#' .env | grep -v '^$' | xargs)

cat > docker-secrets.env <<EOF
# MongoDB
DATABASE_URL=${DATABASE_URL:-}
MONGODB_ROOT_USERNAME=${MONGODB_ROOT_USERNAME:-admin}
MONGODB_ROOT_PASSWORD=${MONGODB_ROOT_PASSWORD:-changeme}

# Milvus
MILVUS_URI=${MILVUS_URI:-http://milvus:19530}
MILVUS_TOKEN=${MILVUS_TOKEN:-}
MILVUS_USER=${MILVUS_USER:-}

# Clerk
CLERK_SECRET_KEY=${CLERK_SECRET_KEY:-}
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=${NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY:-}
CLERK_FRONTEND_API=${CLERK_FRONTEND_API:-https://api.clerk.com}
CLERK_WEBHOOK_SECRET=${CLERK_WEBHOOK_SECRET:-}

# Clerk URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=${NEXT_PUBLIC_CLERK_SIGN_IN_URL:-/sign-in}
NEXT_PUBLIC_CLERK_SIGN_UP_URL=${NEXT_PUBLIC_CLERK_SIGN_UP_URL:-/sign-up}
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=${NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL:-/}
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=${NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL:-/}

# Application
ENVIRONMENT=${ENVIRONMENT:-development}
BUILD_VERSION=${BUILD_VERSION:-1.0.0}

# MinIO
MINIO_ACCESS_KEY=${MINIO_ACCESS_KEY:-minioadmin}
MINIO_SECRET_KEY=${MINIO_SECRET_KEY:-minioadmin}
EOF

# Build images
echo -e "${GREEN}Building Docker images...${NC}"
docker build -t tensorstore-backend:latest -f docker/backend.Dockerfile . --build-arg BUILD_VERSION=${BUILD_VERSION:-1.0.0}
docker build -t tensorstore-frontend:latest -f docker/frontend.Dockerfile . --build-arg NEXT_PUBLIC_FLASK_API_URL="http://backend:5000/service/api"

# Start services (only frontend and backend for cloud databases)
echo -e "${GREEN}Starting services...${NC}"
docker-compose up -d frontend backend

echo -e "\n${GREEN}=== Services Started ===${NC}\n"
echo -e "Frontend: http://localhost:3000"
echo -e "Backend:  http://localhost:5000/service/api\n"
echo -e "View logs: docker-compose logs -f\n"

